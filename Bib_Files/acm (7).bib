url = {https://doi-org.ez24.periodicos.capes.gov.br/10.1145/3764592},
doi = {10.1145/3764592},
abstract = {To mitigate the negative effects of false information more effectively, the development of Artificial Intelligence&nbsp;(AI)&nbsp;systems to assist fact-checkers is needed. Nevertheless, the lack of focus on the needs of these stakeholders results in their limited acceptance and skepticism toward automating the whole fact-checking process. In this study, we conducted semi-structured in-depth interviews with Central European fact-checkers. Their activities and problems were analyzed using iterative content analysis. The most significant problems were validated with a survey of European fact-checkers, in which we collected 24 responses from 20 countries, i.e., 62\% of active European signatories of the International Fact-Checking Network (IFCN). Our contributions include an in-depth examination of the variability of fact-checking work in non-English-speaking regions, which still remained largely uncovered. By aligning them with the knowledge from prior studies, we created conceptual models that help to understand the fact-checking processes. In addition, we mapped our findings on the fact-checkers’ activities and needs to the relevant tasks for AI research, while providing a discussion on three AI tasks that were not covered by previous similar studies. The new opportunities identified for AI researchers and developers have implications for the focus of AI research in this domain.},
journal = {ACM J. Responsib. Comput.},
month = oct,
articleno = {17},
numpages = {42},
keywords = {Fact-checkers, misinformation, disinformation, human-centered artificial intelligence, human-information interaction}
}

@inproceedings{10.1145/3785987.3786056,
author = {Zheng, Xiaoqiang},
title = {The Impact of Perceived Value on Gen Z Users’ Continuance Intention Toward AIGC Platforms from an SOR Perspective},
year = {2026},
isbn = {9798400720956},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi-org.ez24.periodicos.capes.gov.br/10.1145/3785987.3786056},
doi = {10.1145/3785987.3786056},
abstract = {With the rapid development of generative artificial intelligence (AI), its applications in education, research, and knowledge services are expanding, making it a crucial tool for Generation Z learning and knowledge production. Existing research has largely focused on general user groups, with less attention paid to how the unique value perceptions and behavioral characteristics of Generation Z influence their continued use intention on the AIGC learning platform. To address this research gap, this study constructs a "perceived value-satisfaction-continued use intention" model based on the SOR framework, introducing satisfaction as a mediating variable to analyze the pathways through which perceived value influences continued use intention, revealing the psychological mechanisms and behavioral logic behind Generation Z users' use of the AIGC learning platform. This research not only enriches the theoretical literature on AIGC user behavior but also provides empirical evidence and practical insights for the in-depth application of AI in education, helping platforms achieve more precise operations and stronger user engagement. This study also reflects the cutting-edge advancements in computer technology in the advancement of intelligent education, demonstrating how AIGC, as an emerging technology, is reshaping the way knowledge is acquired and expressed.},
booktitle = {Proceedings of the 2025 2nd International Conference on Artificial Intelligence and Future Education},
pages = {420–425},
numpages = {6},
keywords = {AIGC learning platforms, Gen Z, SOR, continuance intention, perceived value theory},
location = {
},
series = {AIFE '25}
}

